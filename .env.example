# ── Database ──────────────────────────────────────────────────────────
DB_DATABASE=thinkertanker
DB_USERNAME=thinkertanker
DB_PASSWORD=secret

# ── Laravel ───────────────────────────────────────────────────────────
# Generate with: php artisan key:generate --show
APP_KEY=

# ── OpenRouter ────────────────────────────────────────────────────────
